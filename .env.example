# ============================================
# CREDLINK ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local for development
# DO NOT commit actual values to git

# ============================================
# DATABASE (Required)
# ============================================
# MySQL connection string
DATABASE_URL="mysql://username:password@host:3306/database_name"

# ============================================
# AUTHENTICATION (Required)
# ============================================
# JWT Secret for session tokens (generate with: openssl rand -base64 32)
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"

# NextAuth Secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-nextauth-secret-key"
NEXTAUTH_URL="http://localhost:3000"

# ============================================
# FIREBASE - PUBLIC (Safe to expose)
# ============================================
NEXT_PUBLIC_FIREBASE_API_KEY="your-firebase-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
NEXT_PUBLIC_FIREBASE_APP_ID="your-app-id"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="G-XXXXXXXXXX"

# ============================================
# FIREBASE - SERVER (Secret - Never expose!)
# ============================================
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@your-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Private-Key\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"

# ============================================
# CLOUDINARY (For image uploads)
# ============================================
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ============================================
# EMAIL SERVICE (For password reset, notifications)
# ============================================
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your-app-password"
EMAIL_FROM="CredLink <noreply@credlink.com>"

# ============================================
# APPLICATION SETTINGS
# ============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ============================================
# CLOUD RUN SPECIFIC (Set in GCP Secret Manager)
# ============================================
# These are set via --set-env-vars and --update-secrets in Cloud Run
# PORT=3000 (automatically set by Cloud Run)
# HOSTNAME=0.0.0.0 (required for Cloud Run)
